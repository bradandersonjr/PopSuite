{
  "extends": "../pop-shared/tsconfig/app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../pop-shared/src/*"],
      "@keys/*": ["../PopKey/src/*"],
      "@jot/*": ["../PopJot/src/*"],
      "@suite/*": ["../PopSuite/src/*"]
    }
  },
  "include": ["src", "../pop-shared/src"],
  // PopKey ships no browser extension; these shared files are PopJot-only and
  // assume PopJot's store shape, so they are excluded from PopKey's typecheck.
  "exclude": [
    "../pop-shared/src/roots/ExtensionRoot.tsx",
    "../pop-shared/src/roots/ExtensionPopup.tsx",
    "../pop-shared/src/extension",
    "../pop-shared/src/utils/extensionStorage.ts"
  ]
}
