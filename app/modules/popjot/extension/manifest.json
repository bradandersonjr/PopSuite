{
  "manifest_version": 3,
  "name": "PopJot",
  "version": "1.0.0",
  "description": "Screen annotation that stays out of your way. Draw over any webpage with a radial tool menu.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PopJot"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["storage", "activeTab", "tabs"],

  "web_accessible_resources": [
    {
      "resources": ["content.css", "popup.css", "*.woff", "*.woff2", "*.ttf", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "homepage_url": "https://popsuite.app"
}
