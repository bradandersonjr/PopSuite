{
  "extends": "../../../shared/tsconfig/app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../../../shared/src/*"]
    }
  },
  "include": ["src", "../../../shared/src"],
  // PopKey ships no browser extension; these shared files are PopJot-only and
  // assume PopJot's store shape, so they are excluded from PopKey's typecheck.
  "exclude": [
    "../../../shared/src/roots/ExtensionRoot.tsx",
    "../../../shared/src/roots/ExtensionPopup.tsx",
    "../../../shared/src/extension",
    "../../../shared/src/utils/extensionStorage.ts"
  ]
}
