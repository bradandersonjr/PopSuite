{
  "name": "PopKey",
  "private": true,
  "license": "FSL-1.1-MIT",
  "version": "1.1.0",
  "description": "On-screen keystroke & mouse-action visualizer for screencasts and demos.",
  "homepage": "https://popsuite.app",
  "author": "Brad Anderson <brad@bradandersonjr.com>",
  "main": "out/main/index.js",
  "scripts": {
    "dev:electron": "electron-vite dev",
    "guard:pro": "node scripts/check-pro-stub.mjs",
    "build:electron": "electron-vite build",
    "build:extension": "vite build --config vite.extension.config.ts --mode popup && node ../../../shared/scripts/build-content.mjs && node ../../../shared/scripts/pack-extension.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-tooltip": "^1.2.7",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uiohook-napi": "^1.5.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/chrome": "^0.1.43",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "electron": "40.10.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  }
}
